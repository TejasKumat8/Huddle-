# Get a free API key from https://console.cloud.google.com/google/maps-apis
# Enable "Places API" and "Maps JavaScript API" for the key, and restrict it
# to your domain (or localhost while developing).
VITE_GOOGLE_MAPS_API_KEY=

# Leave empty for local dev (requests go through the Vite proxy to
# localhost:5000). In production, set to your deployed backend's URL,
# e.g. https://huddle-backend.onrender.com — no trailing slash.
VITE_API_BASE_URL=
